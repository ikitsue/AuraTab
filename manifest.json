{
  "manifest_version": 3,
  "name": "AuraTab - New Tab & Sounds",
  "version": "1.0.0",
  "description": "Personnalisez votre nouvel onglet avec des fonds dynamiques et des effets sonores navigateur",
  "author": "AuraTab Team",
  
  "permissions": [
    "storage",
    "tabs",
    "webNavigation"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "AuraTab Settings",
    "default_icons": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  
  "background": {
    "service_worker": "background.js"
  },
  
  "web_accessible_resources": [
    {
      "resources": [
        "sounds/*",
        "wallpapers/*",
        "images/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
